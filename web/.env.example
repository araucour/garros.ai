# Clé API Resend pour l'envoi des emails du formulaire de contact.
# Obtenir une clé sur https://resend.com (API Keys).
# En local : copier ce fichier en ".env.local" et renseigner la valeur.
# En production : définir cette variable dans Vercel (Settings > Environment Variables).
RESEND_API_KEY=

# Adresse de destination des messages du formulaire (ta boîte de réception).
CONTACT_TO_EMAIL=contact@garros.ai

# Adresse expéditrice vérifiée chez Resend (doit appartenir à un domaine vérifié).
CONTACT_FROM_EMAIL=contact@garros.ai
